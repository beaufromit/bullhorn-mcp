# Bullhorn API Credentials
# Get these from your Bullhorn admin or developer portal

# OAuth 2.0 client credentials
BULLHORN_CLIENT_ID=your_client_id
BULLHORN_CLIENT_SECRET=your_client_secret

# API user credentials (service account recommended)
BULLHORN_USERNAME=your_api_username
BULLHORN_PASSWORD=your_api_password

# Optional: Override default URLs (usually not needed)
# BULLHORN_AUTH_URL=https://auth.bullhornstaffing.com
# BULLHORN_LOGIN_URL=https://rest.bullhornstaffing.com

# Transport mode: "stdio" (default, for local clients) or "http" (for hosted deployments)
# MCP_TRANSPORT=stdio

# HTTP mode settings — only used when MCP_TRANSPORT=http
# PORT=8000
# HOST=0.0.0.0

# Microsoft Entra OAuth (required for remote HTTP deployment)
# Note: offline_access scope is requested automatically by the server
# to enable session persistence. No additional configuration is required.
ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=
ENTRA_CLIENT_SECRET=
MCP_BASE_URL=

# === JobOrder per-instance configuration (all optional) ===

# Field aliases: extends the hardcoded FIELD_ALIASES with instance-specific
# mappings. Useful when Bullhorn's metadata label is not what your team types,
# or to give custom fields friendly names. Format: JSON object of
# {"alias_lowercase": "api_field_name"}. Env entries override hardcoded ones.
# BULLHORN_JOBORDER_ALIASES='{"sector": "customText1", "salary range": "customText10", "location": "customText11", "grade": "correlatedCustomText2", "fee": "feeArrangement"}'

# Additional required fields beyond Bullhorn's hard API minimum of title,
# clientCorporation, and clientContact. Job creation is rejected if any are
# missing after defaults are merged. Format: JSON array of API field names
# or aliases that resolve to them.
# BULLHORN_JOBORDER_REQUIRED='["source", "salary"]'

# Default values applied when the caller does not specify a field. Caller
# values always win on conflict. Format: JSON object of {"field_name_or_alias": value}.
# BULLHORN_JOBORDER_DEFAULTS='{"status": "Accepting Candidates", "isOpen": true, "customText12": 0}'